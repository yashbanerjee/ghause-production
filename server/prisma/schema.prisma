generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id       String @id
  email    String @unique
  password String
}

model Category {
  id                       String    @id
  nameEn                   String
  nameAr                   String
  nameFr                   String?
  icon                     String?
  image                    String?
  createdAt                DateTime  @default(now())
  homeDescriptionAr        String?
  homeDescriptionEn        String?
  homeDescriptionFr        String?
  productPageDescriptionAr String?
  productPageDescriptionEn String?
  productPageDescriptionFr String?
  isActive                 Boolean   @default(true)
  Product                  Product[]
}

model Enquiry {
  id          String   @id
  name        String
  email       String
  phone       String?
  address     String?
  country     String?
  comment     String
  productName String?
  createdAt   DateTime @default(now())
  company     String?
  status      String   @default("unread")
  subject     String?
  type        String   @default("PRODUCT")
}

model Product {
  id            String   @id
  nameEn        String
  nameAr        String
  nameFr        String?
  descriptionEn String
  descriptionAr String
  descriptionFr String?
  image         String?
  categoryId    String
  createdAt     DateTime @default(now())
  catalogs      String[] @default([])
  isActive      Boolean  @default(true)
  isFeatured    Boolean  @default(false)
  Category      Category @relation(fields: [categoryId], references: [id])
}
